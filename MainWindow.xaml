<Window x:Class="ExcelToSqlImporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ExcelToSqlImporter"
        Title="SimplePOS Data Exporter - Export Data from Excel → SQL Server · Opening Stock"
        Height="820" Width="1100"
        MinHeight="720" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToTickConverter    x:Key="BoolToTick"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Connection -->
            <RowDefinition Height="Auto"/>   <!-- File picker -->
            <RowDefinition Height="*"/>      <!-- Preview grid -->
            <RowDefinition Height="Auto"/>   <!-- Progress / actions -->
            <RowDefinition Height="190"/>    <!-- Import log -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ══════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Simple POS Data Exporter - Export Data from Excel → SQL Server"
                       FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock FontSize="13" Foreground="#64748B" Margin="0,3,0,0">
                <Run Text="SimplePOS Database  ·  Opening Stock Entry  ·  9 tables per row" FontWeight="SemiBold" Foreground="#2563EB"/>
            </TextBlock>
        </StackPanel>

        <!-- ═══ CONNECTION ══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔗  Connection String"
                           FontWeight="SemiBold" Foreground="#334155"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>

                <TextBox   Grid.Column="1"
                           x:Name="TxtConnectionString"
                           Style="{StaticResource ModernTextBox}"
                           Text="Server=.\SQLEXPRESS;Database=SimplePOSDB;Trusted_Connection=True;TrustServerCertificate=True;"
                           ToolTip="Paste your SQL Server Express connection string"
                           Margin="0,0,10,0"/>

                <Button    Grid.Column="2"
                           Style="{StaticResource SecondaryButton}"
                           Content="🔌  Test Connection"
                           Click="BtnTestConnection_Click"
                           Margin="0,0,10,0"/>

                <TextBlock Grid.Column="3"
                           x:Name="TxtConnectionStatus"
                           VerticalAlignment="Center"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="#64748B"/>
            </Grid>
        </Border>

        <!-- ═══ FILE PICKER ═════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📂  Excel File"
                           FontWeight="SemiBold" Foreground="#334155"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>

                <TextBox   Grid.Column="1"
                           x:Name="TxtFilePath"
                           Style="{StaticResource ModernTextBox}"
                           IsReadOnly="True"
                           Foreground="#64748B"
                           Text="No file selected..."
                           Margin="0,0,10,0"/>

                <!-- x:Name="BtnBrowse" — must match FindName("BtnBrowse") in code-behind -->
                <Button    Grid.Column="2"
                           x:Name="BtnBrowse"
                           Style="{StaticResource SecondaryButton}"
                           Content="Browse..."
                           Click="BtnBrowse_Click"
                           Margin="0,0,10,0"/>

                <Button    Grid.Column="3"
                           Style="{StaticResource PrimaryButton}"
                           Content="📋  Preview Data"
                           Click="BtnPreview_Click"/>
            </Grid>
        </Border>

        <!-- ═══ PREVIEW GRID ════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Badge row -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Data Preview"
                                   FontWeight="SemiBold" Foreground="#334155" FontSize="14"/>
                        <Border Background="#EFF6FF" CornerRadius="12"
                                Padding="10,3" Margin="12,0,0,0">
                            <TextBlock x:Name="TxtRowCount"
                                       Text="0 rows" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#2563EB"/>
                        </Border>
                        <Border x:Name="BadgeWarnings" Background="#FEF3C7" CornerRadius="12"
                                Padding="10,3" Margin="8,0,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="TxtWarningCount"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#D97706"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                               FontSize="11" Foreground="#94A3B8"
                               Text="DB Name = truncated to 40 chars  ·  Size = extracted from product name"/>
                </Grid>

                <!-- Data grid -->
                <DataGrid Grid.Row="1"
                          x:Name="PreviewGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MinHeight="150" MaxHeight="210"
                          BorderThickness="1" BorderBrush="#E2E8F0"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          HeadersVisibility="Column"
                          FontSize="12">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"       Value="#F1F5F9"/>
                            <Setter Property="Foreground"       Value="#475569"/>
                            <Setter Property="FontWeight"       Value="SemiBold"/>
                            <Setter Property="Padding"          Value="8,6"/>
                            <Setter Property="BorderThickness"  Value="0,0,1,1"/>
                            <Setter Property="BorderBrush"      Value="#E2E8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Row"
                            Binding="{Binding RowNumber}"    Width="42"/>
                        <DataGridTextColumn Header="Product Code"
                            Binding="{Binding ProductCode}"  Width="135"/>
                        <DataGridTextColumn Header="Brand"
                            Binding="{Binding ProductBrand}" Width="95"/>
                        <DataGridTextColumn Header="Product Name (Original)"
                            Binding="{Binding ProductName}"  Width="*"/>
                        <DataGridTextColumn Header="DB Name (≤40)"
                            Binding="{Binding ProductNameDb}" Width="155"/>
                        <DataGridTextColumn Header="Size"
                            Binding="{Binding ProductSize}"  Width="50"/>
                        <DataGridTextColumn Header="Category"
                            Binding="{Binding Category}"     Width="95"/>
                        <DataGridTextColumn Header="Group"
                            Binding="{Binding Group}"        Width="85"/>
                        <DataGridTextColumn Header="Qty"
                            Binding="{Binding Quantity}"     Width="55"/>
                        <DataGridTextColumn Header="Cost"
                            Binding="{Binding CostPrice,    StringFormat=N2}" Width="75"/>
                        <DataGridTextColumn Header="Price"
                            Binding="{Binding SellingPrice, StringFormat=N2}" Width="75"/>
                        <DataGridTextColumn Header="Total Value"
                            Binding="{Binding TotalValue,   StringFormat=N2}" Width="85"/>
                        <DataGridTemplateColumn Header="✓" Width="38">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding IsValid, Converter={StaticResource BoolToTick}}"
                                        HorizontalAlignment="Center"
                                        ToolTip="{Binding ValidationMessage}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ═══ PROGRESS + ACTIONS ══════════════════════════════════════════ -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Badges + Buttons -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Summary badges -->
                    <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#DCFCE7" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock x:Name="TxtNewCount"
                                       Text="✅ New: 0"
                                       Foreground="#16A34A" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#DBEAFE" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock x:Name="TxtStockCount"
                                       Text="🔄 Stock Added: 0"
                                       Foreground="#2563EB" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#FEF9C3" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock x:Name="TxtSkippedCount"
                                       Text="⚠️ Skipped: 0"
                                       Foreground="#CA8A04" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#FEE2E2" CornerRadius="12" Padding="10,4">
                            <TextBlock x:Name="TxtErrorCount"
                                       Text="❌ Errors: 0"
                                       Foreground="#DC2626" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </WrapPanel>

                    <Button Grid.Column="1"
                            x:Name="BtnCancel"
                            Style="{StaticResource SecondaryButton}"
                            Content="⛔  Cancel"
                            Click="BtnCancel_Click"
                            IsEnabled="False"
                            Margin="0,0,10,0"/>

                    <Button Grid.Column="2"
                            x:Name="BtnImport"
                            Style="{StaticResource SuccessButton}"
                            Content="🚀  Import to SQL Server"
                            Click="BtnImport_Click"
                            IsEnabled="False"
                            MinWidth="185"/>
                </Grid>

                <!-- Progress bar -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="ImportProgress"
                                 Grid.Column="0"
                                 Height="12"
                                 Minimum="0" Maximum="100" Value="0"
                                 Foreground="#2563EB"
                                 Background="#E2E8F0"
                                 Margin="0,0,10,0"/>
                    <TextBlock   Grid.Column="1"
                                 x:Name="TxtProgressLabel"
                                 Text="0%"
                                 Foreground="#64748B" FontSize="12"
                                 VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ IMPORT LOG ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="5" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Import Log"
                               FontWeight="SemiBold" Foreground="#334155" FontSize="14"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="📄  Export Log as CSV"
                            Click="BtnExportLog_Click"
                            Padding="12,4" FontSize="12"/>
                </Grid>

                <ListBox Grid.Row="1"
                         x:Name="ImportLog"
                         Background="#0F172A"
                         Foreground="#94A3B8"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="11"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

    </Grid>
</Window>
